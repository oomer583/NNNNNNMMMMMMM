{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "User storytelling project mapping cards and connections.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "Card": {
      "title": "Card",
      "description": "An atomic unit of thought in the board.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "type": { "type": "string" },
        "category": { "type": "string" },
        "data": { "type": "object" },
        "position": { "type": "object" }
      },
      "required": ["projectId", "type"]
    }
  },
  "firestore": {
    "projects": {
      "schema": "Project",
      "description": "Main project documents."
    },
    "cards": {
      "schema": "Card",
      "description": "Nodes within a project."
    },
    "edges": {
      "schema": "object",
      "description": "Connections between cards."
    }
  }
}
